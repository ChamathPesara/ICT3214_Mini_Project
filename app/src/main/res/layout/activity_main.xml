<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- App Icon -->
        <TextView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:background="@drawable/bg_card"
            android:elevation="6dp"
            android:gravity="center"
            android:text="🍲"
            android:textSize="38sp" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Welcome"
            android:textColor="@color/c_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="30dp"
            android:text="What would you like to do today?"
            android:textColor="@color/c_hint"
            android:textSize="14sp" />

        <!-- Button Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="8dp"
            android:orientation="vertical">

            <!-- Add Recipe -->
            <Button
                android:id="@+id/btnAddRecipe"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_gradient"
                android:text="Add Recipe"
                android:textAllCaps="false"
                android:textColor="@color/c_white"
                android:textStyle="bold" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <!-- View Recipes -->
            <Button
                android:id="@+id/btnViewRecipes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_outline"
                android:text="View Recipes"
                android:textAllCaps="false"
                android:textColor="@color/c_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Happy cooking 🍳"
            android:textColor="@color/c_hint"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>