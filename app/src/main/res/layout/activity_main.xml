<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:layoutMode="opticalBounds">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:background="@drawable/bg_card"
            android:elevation="6dp"
            android:padding="0dp"
            android:scaleType="fitCenter"
            android:src="@drawable/recipe_logo" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/aclonica"
            android:text="Welcome !!!"
            android:textColor="@color/c_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="30dp"
            android:fontFamily="@font/alata"
            android:text="What would you like to do today?"
            android:textColor="@color/c_hint"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="8dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnAddRecipe"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_gradient"
                android:fontFamily="@font/baloo"
                android:text="Add Recipe"
                android:textAllCaps="false"
                android:textColor="@color/c_white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <Button
                android:id="@+id/btnViewRecipes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_outline"
                android:fontFamily="@font/baloo"
                android:text="View Recipes"
                android:textAllCaps="false"
                android:textColor="@color/c_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/alata"
            android:text="Happy cooking 🍳"
            android:textColor="@color/c_hint"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>